@model Ogrenci_Not_Kayit_Sistemi.Models.Ders

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8" />
    <title>Notlarım</title>
</head>
<body>
    <div class="header">
        <div>
            <h1>📊 Not Görüntüleme</h1>
            <p>Öğrenci No: @Context.Session.GetString("OgrNumara")</p>
        </div>
        <a href="/Login/Logout" class="btn-logout">🚪 Çıkış Yap</a>
    </div>

    @if (Model == null)
    {
        <div style="text-align:center; color:white; font-size:20px; margin-top:50px;">
            ⚠️ Kayıtlı notunuz bulunamadı.
        </div>
    }
    else
    {
        <div class="student-card">
            <div class="student-info">
                <div class="avatar">👨‍🎓</div>
                <div>
                    <h2>@Model.OgrAd @Model.OgrSoyad</h2>
                    <p>📋 Öğrenci No: @Model.OgrNumara</p>
                </div>
            </div>

            
            <div class="grades-grid">
                <div class="grade-box">
                    <div class="grade-label">1. Sınav</div>
                    @if (Model.Ogrs1.HasValue)
                    {
                        <div class="grade-value">@Model.Ogrs1</div>
                    }
                    else
                    {
                        <div class="grade-value empty">-</div>
                    }
                </div>
                <div class="grade-box">
                    <div class="grade-label">2. Sınav</div>
                    @if (Model.Ogrs2.HasValue)
                    {
                        <div class="grade-value">@Model.Ogrs2</div>
                    }
                    else
                    {
                        <div class="grade-value empty">-</div>
                    }
                </div>
                <div class="grade-box">
                    <div class="grade-label">3. Sınav</div>
                    @if (Model.Ogrs3.HasValue)
                    {
                        <div class="grade-value">@Model.Ogrs3</div>
                    }
                    else
                    {
                        <div class="grade-value empty">-</div>
                    }
                </div>
            </div>

           
            @if (Model.Ogrs3.HasValue && Model.Ortalama.HasValue)
            {
                <div class="avg-box">
                    <div class="grade-label">📊 Ortalama</div>
                    <div class="grade-value">@Model.Ortalama</div>
                </div>
            }
            else
            {
                <div class="pending-box">
                    ⏳ Ortalama henüz hesaplanmadı — 3. sınav bekleniyor
                </div>
            }

         
            @if (Model.Durum.HasValue)
            {
                if (Model.Durum == true)
                {
                    <div class="result-box result-pass">
                        <div class="result-icon">🏆</div>
                        <div class="result-text">GEÇTİ</div>
                        <div class="result-avg">Ortalama: @Model.Ortalama</div>
                    </div>
                }
                else
                {
                    <div class="result-box result-fail">
                        <div class="result-icon">😔</div>
                        <div class="result-text">KALDI</div>
                        <div class="result-avg">Ortalama: @Model.Ortalama</div>
                    </div>
                }
            }
            else
            {
                <div class="pending-box" style="margin-top: 15px;">
                    📋 Tüm sınavlar tamamlandığında sonuç görünecek
                </div>
            }

        </div>
    }
</body>
</html>

<style>
    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    body {
        min-height: 100vh;
        background: linear-gradient(135deg, #11998e, #38ef7d);
        font-family: 'Segoe UI', sans-serif;
        padding: 30px;
    }

    .header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 30px;
    }

        .header h1 {
            color: white;
            font-size: 28px;
            font-weight: 700;
        }

        .header p {
            color: rgba(255,255,255,0.8);
            font-size: 14px;
            margin-top: 4px;
        }

    .btn-logout {
        background: rgba(255,255,255,0.2);
        color: white;
        border: 2px solid rgba(255,255,255,0.5);
        padding: 10px 20px;
        border-radius: 10px;
        text-decoration: none;
        font-weight: 600;
        transition: all 0.3s;
    }

        .btn-logout:hover {
            background: rgba(255,255,255,0.3);
        }

    .student-card {
        background: white;
        border-radius: 20px;
        padding: 35px;
        max-width: 700px;
        margin: 0 auto;
        box-shadow: 0 20px 60px rgba(0,0,0,0.2);
    }

    .student-info {
        display: flex;
        align-items: center;
        gap: 20px;
        padding-bottom: 25px;
        border-bottom: 2px solid #f0f4f8;
        margin-bottom: 30px;
    }

    .avatar {
        width: 70px;
        height: 70px;
        background: linear-gradient(135deg, #11998e, #38ef7d);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 30px;
        flex-shrink: 0;
    }

    .student-info h2 {
        font-size: 22px;
        font-weight: 700;
        color: #2d3748;
    }

    .student-info p {
        color: #718096;
        font-size: 14px;
        margin-top: 4px;
    }

    .grades-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 15px;
        margin-bottom: 20px;
    }

    .grade-box {
        background: linear-gradient(135deg, #667eea15, #764ba215);
        border: 2px solid #667eea30;
        border-radius: 14px;
        padding: 20px;
        text-align: center;
    }

    .grade-label {
        font-size: 12px;
        font-weight: 600;
        color: #718096;
        text-transform: uppercase;
        margin-bottom: 8px;
    }

    .grade-value {
        font-size: 36px;
        font-weight: 800;
        color: #667eea;
    }

        .grade-value.empty {
            font-size: 28px;
            color: #cbd5e0;
        }

    .avg-box {
        background: linear-gradient(135deg, #667eea20, #764ba220);
        border: 2px solid #667eea50;
        border-radius: 14px;
        padding: 20px;
        text-align: center;
        margin-bottom: 20px;
    }

        .avg-box .grade-label {
            color: #553c9a;
        }

        .avg-box .grade-value {
            color: #553c9a;
        }

    .pending-box {
        text-align: center;
        color: #a0aec0;
        font-size: 14px;
        padding: 18px;
        background: #f7fafc;
        border-radius: 12px;
        border: 2px dashed #e2e8f0;
        margin-bottom: 20px;
    }

    .result-box {
        border-radius: 16px;
        padding: 25px;
        text-align: center;
    }

    .result-pass {
        background: linear-gradient(135deg, #c6f6d5, #f0fff4);
        border: 2px solid #9ae6b4;
    }

    .result-fail {
        background: linear-gradient(135deg, #fed7d7, #fff5f5);
        border: 2px solid #fc8181;
    }

    .result-icon {
        font-size: 48px;
        margin-bottom: 10px;
    }

    .result-text {
        font-size: 22px;
        font-weight: 800;
    }

    .result-pass .result-text {
        color: #276749;
    }

    .result-fail .result-text {
        color: #c53030;
    }

    .result-avg {
        font-size: 15px;
        margin-top: 5px;
    }

    .result-pass .result-avg {
        color: #2f855a;
    }

    .result-fail .result-avg {
        color: #9b2c2c;
    }
</style>
